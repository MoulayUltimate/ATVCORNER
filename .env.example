NEXT_PUBLIC_SITE_URL=https://atvcorner.com
NEXT_PUBLIC_WHATSAPP_NUMBER=447796630011

# --- Admin panel ---
# Password the operator types at /admin/login.
ADMIN_PASSWORD=change-me-to-something-long
# 32+ random chars — used to HMAC-sign the admin session cookie.
# Generate: `openssl rand -hex 32`
ADMIN_SESSION_SECRET=replace-with-openssl-rand-hex-32

# --- Analytics storage (Upstash Redis REST) ---
# Sign up at https://upstash.com → Create a Redis DB → copy REST URL + token.
# If unset, analytics writes go to in-memory storage (lost on redeploy).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
